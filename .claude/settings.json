      "Bash(xcodegen generate:*)",
      "Bash(xcrun devicectl:*)",
      "Edit",
      "Edit(//tmp/**)",
      "Read",
      "Read(//tmp/**)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:interhuman.ai)",
      "WebFetch(domain:linear.app)",
      "Write",
      "Write(//tmp/**)",
      "mcp__claude_ai_Linear__*",
      "mcp__Claude_Code_Remote__subscribe_pr_activity",
      "mcp__Claude_Code_Remote__send_later",
      "mcp__Claude_Code_Remote__*",
      "mcp__context7__*",
      "mcp__github__*",
      "mcp__ide__*",
      "mcp__linear__*",
      "mcp__playwright__*",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_close",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_github_github__*",
      "mcp__plugin_linear_linear__*",
      "mcp__plugin_mcp_context7__*",
      "mcp__plugin_playwright_playwright__*",
      "mcp__sequential-thinking__*"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "remote",
        "hooks": [
          {
            "type": "command",
            "command": "export GH_TOKEN=\"$(op read 'op://Personal/d4f7rto4ctzswk4wtwtawe7l4a/credential')\""
          }
        ]
      },
      {
        "matcher": "remote",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; data=json.load(sys.stdin); cmd=data.get('command','').strip(); blocked=['ls','grep','find','cat','head','tail','sed','awk']; first=cmd.split()[0] if cmd else ''; sys.exit(2) if first in blocked else None\" 2>&1 || (echo 'BLOCKED: Use dedicated tools instead of Bash for file ops: Glob(find/ls), Grep(grep), Read(cat/head/tail/sed)' && exit 2)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -E '\\.py$' | xargs -r uv run ruff format"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true
  },
  "alwaysThinkingEnabled": true,
  "promptSuggestionEnabled": false,
  "tui": "fullscreen"
}
